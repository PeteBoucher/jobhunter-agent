# ── CLI / Lambda scraper ─────────────────────────────────────────────────────

# Database (SQLite for local CLI, PostgreSQL for Lambda + web API)
DATABASE_URL=sqlite:///./data/jobs.db

# Adzuna API (https://developer.adzuna.com/)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# GitHub API token (for scraping GitHub Jobs / public repos)
GITHUB_TOKEN=your_github_token_here

# Anthropic API key (AI-powered CV parsing and job matching)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auto-apply settings (CLI only)
AUTO_APPLY_THRESHOLD=75
AUTO_APPLY_ENABLED=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/agent.log


# ── Web API (web/api/) ────────────────────────────────────────────────────────
# Copy web/api/.env.example → web/api/.env and fill in:
#
# DATABASE_URL=postgresql://user:pass@host/jobhunter    ← Neon connection string
# JWT_SECRET=<random 32-char string>
# GOOGLE_CLIENT_ID=<from Google Cloud Console>
# CORS_ORIGINS=http://localhost:3000,https://yourapp.vercel.app


# ── Next.js frontend (web/frontend/) ─────────────────────────────────────────
# Copy web/frontend/.env.local.example → web/frontend/.env.local and fill in:
#
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=<random 32-char string>
# GOOGLE_CLIENT_ID=<from Google Cloud Console>
# GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
# NEXT_PUBLIC_API_URL=http://localhost:8000
