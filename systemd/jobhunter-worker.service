[Unit]
Description=Job Hunter Agent Background Worker
After=network.target

[Service]
Type=simple
User=jobhunter
WorkingDirectory=/opt/jobhunter-agent
ExecStart=/opt/jobhunter-agent/.venv/bin/python -m src.cli worker
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
