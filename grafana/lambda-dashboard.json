{
  "title": "Jobhunter Lambda",
  "uid": "jobhunter-lambda",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Jobs scraped (last run)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message like /\"jobs_scraped\"/ | parse @message '\"jobs_scraped\": *,' as jobs_scraped | sort @timestamp desc | limit 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Scraper errors (window)",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @message | filter @message like /Error scraping/ | stats count() as errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Zero-result scrapers (window)",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @message | filter @message like /returned 0 raw results/ | stats count() as zero_scrapers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Lambda invocations & errors",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Metrics",
          "region": "eu-west-1",
          "namespace": "AWS/Lambda",
          "metricName": "Invocations",
          "dimensions": {
            "FunctionName": "jobhunter-prod"
          },
          "statistic": "Sum",
          "period": "21600",
          "refId": "A",
          "alias": "Invocations",
          "matchExact": true
        },
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Metrics",
          "region": "eu-west-1",
          "namespace": "AWS/Lambda",
          "metricName": "Errors",
          "dimensions": {
            "FunctionName": "jobhunter-prod"
          },
          "statistic": "Sum",
          "period": "21600",
          "refId": "B",
          "alias": "Errors",
          "matchExact": true
        }
      ]
    },
    {
      "id": 5,
      "title": "New jobs scraped per run",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message like /\"jobs_scraped\"/ | parse @message '\"jobs_scraped\": *,' as jobs_scraped | stats sum(jobs_scraped) by bin(6h)",
          "statsGroups": [
            "bin(6h)"
          ],
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Lambda duration (ms)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Metrics",
          "region": "eu-west-1",
          "namespace": "AWS/Lambda",
          "metricName": "Duration",
          "dimensions": {
            "FunctionName": "jobhunter-prod"
          },
          "statistic": "Average",
          "period": "21600",
          "refId": "A",
          "alias": "Average",
          "matchExact": true
        },
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Metrics",
          "region": "eu-west-1",
          "namespace": "AWS/Lambda",
          "metricName": "Duration",
          "dimensions": {
            "FunctionName": "jobhunter-prod"
          },
          "statistic": "p90",
          "period": "21600",
          "refId": "B",
          "alias": "p90",
          "matchExact": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Per-scraper new jobs",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 10,
        "h": 8
      },
      "options": {
        "sortBy": [
          {
            "displayName": "new_jobs",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @message | filter @message like /Scraped/ and @message like /new jobs from/ | parse @message 'Scraped * new jobs from * (raw fetched: *)' as new_jobs, source, raw_fetched | stats sum(new_jobs) as new_jobs, sum(raw_fetched) as raw_fetched by source | sort new_jobs desc",
          "statsGroups": [
            "source"
          ],
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Errors & warnings",
      "type": "logs",
      "gridPos": {
        "x": 10,
        "y": 12,
        "w": 14,
        "h": 8
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @timestamp, @message | filter @message like /ERROR/ or @message like /Error scraping/ or @message like /returned 0 raw/ | sort @timestamp desc | limit 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "All Lambda logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudwatch"
          },
          "queryMode": "Logs",
          "region": "eu-west-1",
          "logGroups": [
            {
              "arn": "arn:aws:logs:eu-west-1:624372908505:log-group:/aws/lambda/jobhunter-prod:*",
              "name": "/aws/lambda/jobhunter-prod"
            }
          ],
          "expression": "fields @timestamp, @message | sort @timestamp desc | limit 200",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "API request rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 20
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-jobhunter-logs"
          },
          "expr": "sum(rate({service=\"jobhunter-api\"} |= \"request method\" [1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-jobhunter-logs"
          },
          "expr": "sum(rate({service=\"jobhunter-api\", level=\"error\"} [1m]))",
          "legendFormat": "errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "API errors & warnings",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-jobhunter-logs"
          },
          "expr": "{service=\"jobhunter-api\"} |~ \"ERROR|WARNING\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "API all logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-jobhunter-logs"
          },
          "expr": "{service=\"jobhunter-api\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
